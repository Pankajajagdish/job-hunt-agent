ADZUNA_APP_ID=
ADZUNA_APP_KEY=
SERPAPI_KEY=
# RapidAPI JSearch — real LinkedIn/Indeed/Google jobs (https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch)
RAPIDAPI_KEY=
# Comma-separated RSS feeds (LinkedIn job alert RSS URLs). Use LinkedIn "Alert" → "RSS" URLs.
RSS_FEED_URLS=
# Path to base resume DOCX in the repository. If set, the agent will preserve layout and replace sections.
# Example: PANKAJA_DevopsEngineer_Resume.docx (your actual resume file)
BASE_RESUME_DOCX=PANKAJA_DevopsEngineer_Resume.docx
# Background refresh interval (minutes)
JOB_POLL_INTERVAL_MIN=5
DAILY_APPLY_GOAL=50
# Backend host for Android emulator: use 10.0.2.2:8000
HOST=0.0.0.0
PORT=8000
